# VaultHound Environment Configuration
# Copy this file to .env and fill in your values

# GitHub Personal Access Token (required for repository access)
# Create at: https://github.com/settings/tokens
# Required scope: repo (read-only)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (optional - for GPT-4o semantic analysis)
# Create at: https://platform.openai.com/api-keys
# Without this, entropy-based detection only will be used
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Custom entropy threshold (default: 4.5)
ENTROPY_THRESHOLD=4.5

# Optional: Log level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO
